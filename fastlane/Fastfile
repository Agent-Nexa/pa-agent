# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do

    # Configure the Apple Store Connect API key to bypass explicitly hardcoding credentials
    # Require these environment values from GitHub secrets:
    # APP_STORE_CONNECT_API_KEY_KEY_ID
    # APP_STORE_CONNECT_API_KEY_ISSUER_ID
    # APP_STORE_CONNECT_API_KEY_KEY (Base64 encoded)

    key_id = ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"]
    key_base64 = ENV["APP_STORE_CONNECT_API_KEY"]

    # 1. Decode the base64 key into a .p8 file so xcodebuild can read it
    p8_path = File.absolute_path("AuthKey_#{key_id}.p8")
    require 'base64'
    File.write(p8_path, Base64.decode64(key_base64))

    # Setup Fastlane ASC API Key for upload_to_testflight
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: p8_path,
      in_house: false # Set to true if you are using an Enterprise account
    )

    # Ensure CI handles keychains safely without prompting for passwords
    setup_ci if ENV["CI"]

    # 2. Make sure Automatic Code Signing is enabled to let Xcode handle everything
    enable_automatic_code_signing(path: "pa-agent.xcodeproj")

    # 3. Build the iOS application, passing the API Key directly to xcodebuild
    build_app(
      project: "pa-agent.xcodeproj", 
      scheme: "pa-agent",
      clean: true,
      export_method: "app-store", # Required for TestFlight distribution
      # The magic: Instruct Xcode to manage profiles using the App Store Connect API Key natively
      xcargs: "-allowProvisioningUpdates -authenticationKeyPath '#{p8_path}' -authenticationKeyID '#{key_id}' -authenticationKeyIssuerID '#{issuer_id}'",
      export_options: {
        method: "app-store",
      }
    )

    # 4. Upload the .ipa generated by build_app to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true # Saves runner time. TestFlight takes time.
    )

    # Optional notification integrations, e.g., Slack
    # slack(message: "Successfully uploaded a new beta build to TestFlight")
  end
end
