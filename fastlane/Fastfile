# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do

    # Configure the Apple Store Connect API key to bypass explicitly hardcoding credentials
    # Require these environment values from GitHub secrets:
    # APP_STORE_CONNECT_API_KEY_KEY_ID
    # APP_STORE_CONNECT_API_KEY_ISSUER_ID
    # APP_STORE_CONNECT_API_KEY_KEY (Base64 encoded)

    key_id = ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"]
    issuer_id = ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"]
    key_base64 = ENV["APP_STORE_CONNECT_API_KEY"] || ENV["APP_STORE_CONNECT_API_KEY_KEY"]

    UI.user_error!("Missing APP_STORE_CONNECT_API_KEY_KEY_ID") if key_id.to_s.strip.empty?
    UI.user_error!("Missing APP_STORE_CONNECT_API_KEY_ISSUER_ID") if issuer_id.to_s.strip.empty?
    UI.user_error!("Missing APP_STORE_CONNECT_API_KEY (or APP_STORE_CONNECT_API_KEY_KEY)") if key_base64.to_s.strip.empty?

    # 1. Decode the base64 key into a .p8 file so xcodebuild can read it
    p8_path = File.absolute_path("AuthKey_#{key_id}.p8")
    require 'base64'
    File.write(p8_path, Base64.decode64(key_base64))

    # Setup Fastlane ASC API Key for upload_to_testflight
    api_key = app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: p8_path,
      in_house: false # Set to true if you are using an Enterprise account
    )

    # Ensure CI handles keychains safely without prompting for passwords
    setup_ci if ENV["CI"]

    # Print useful diagnostics before build
    sh("xcode-select -p")
    sh("xcodebuild -version")
    sh("xcodebuild -list -project pa-agent.xcodeproj")

    # 2. Optional: use match-managed App Store signing assets (recommended for CI)
    if ENV["MATCH_GIT_URL"].to_s.strip.empty?
      UI.important("MATCH_GIT_URL is not set. CI will rely on automatic signing and may try to create new certificates.")
      UI.important("Your current failure indicates certificate quota was reached. Set up match or revoke old certificates in Apple Developer.")
    else
      match(
        api_key: api_key,
        type: "appstore",
        app_identifier: ["z.Nexa"],
        readonly: ENV["CI"].to_s == "true"
      )
    end

    # 3. Build the iOS application, passing the API Key directly to xcodebuild
    begin
      build_app(
        project: "pa-agent.xcodeproj",
        scheme: "pa-agent",
        configuration: "Release",
        clean: true,
        export_method: "app-store", # Required for TestFlight distribution
        buildlog_path: "./fastlane/build_logs",
        # Instruct Xcode to manage profiles using the App Store Connect API Key natively
        xcargs: "-allowProvisioningUpdates -authenticationKeyPath '#{p8_path}' -authenticationKeyID '#{key_id}' -authenticationKeyIssuerID '#{issuer_id}'",
        export_options: {
          method: "app-store",
        }
      )
    rescue => build_error
      UI.error("build_app failed: #{build_error}")

      # Print local gym log (from configured buildlog_path)
      local_log = Dir["./fastlane/build_logs/*.log"].max_by { |f| File.mtime(f) }
      if local_log && File.exist?(local_log)
        UI.important("Latest local gym log: #{local_log}")
        UI.important("---- Last 200 lines ----")
        puts(File.readlines(local_log).last(200).join)
      end

      # Print runner gym log path shown in CI output
      runner_log = "/Users/runner/Library/Logs/gym/nexa-pa-agent.log"
      if File.exist?(runner_log)
        UI.important("Runner gym log: #{runner_log}")
        UI.important("---- Last 200 lines ----")
        puts(File.readlines(runner_log).last(200).join)
      else
        UI.important("Runner gym log not found at #{runner_log}")
      end

      raise build_error
    end

    # 4. Upload the .ipa generated by build_app to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true # Saves runner time. TestFlight takes time.
    )

    # Optional notification integrations, e.g., Slack
    # slack(message: "Successfully uploaded a new beta build to TestFlight")
  end
end
